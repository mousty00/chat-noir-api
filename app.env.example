
SPRING_PROFILES_ACTIVE=docker

# Database (must match database.env)
PGUSER=user
PGPASSWORD=yourpassword
SPRING_DATASOURCE_URL=jdbc:postgresql://database:5432/chat_noir

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=change-me-minimum-32-characters-required
JWT_EXPIRATION=86400000

# Google OAuth2 (optional — OAuth2 login disabled if not set)
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
# SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:8080/api/login/oauth2/code/google

# AWS S3 (optional — file uploads disabled if not set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-north-1
# AWS_S3_BUCKET=your-bucket-name

# Frontend (for OAuth2 redirect)
FRONTEND_DOMAIN=localhost:3000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_APP=INFO
